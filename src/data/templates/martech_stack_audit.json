    "metrics": [
      {
        "label": "Completion Rate",
        "calculation": "Fields completed / Total fields",
        "format": "percentage"
      },
      {
        "label": "Total Sections",
        "calculation": "Number of form sections",
        "format": "number"
      }
    ]
  },
