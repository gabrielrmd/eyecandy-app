        {
          "id": "owner",
          "header": "Owner",
          "type": "text"
        },
        {
          "id": "access_link",
          "header": "Access Link",
          "type": "url"
        }
      ],
      "groupBy": "category"
    },
    {
      "id": "brand_audit",
      "name": "Brand Audit",
      "type": "table",
      "columns": [
        {
          "id": "touchpoint",
          "header": "Touchpoint",
          "type": "text"
        },
        {
          "id": "channel",
          "header": "Channel",
          "type": "text"
        },
        {
          "id": "logo_correct",
          "header": "Logo Correct",
          "type": "text"
        },
        {
          "id": "colours_correct",
          "header": "Colours Correct",
          "type": "text"
        },
        {
          "id": "typography_correct",
          "header": "Typography Correct",
          "type": "text"
        },
        {
          "id": "tone_correct",
          "header": "Tone Correct",
          "type": "text"
        },
        {
          "id": "overall_score",
          "header": "Overall Score",
          "type": "score",
          "min": 1,
          "max": 5,
          "colorScale": {
            "ranges": [
              {
                "min": 1,
                "max": 2,
                "color": "#ef4444"
              },
              {
                "min": 3,
                "max": 3,
                "color": "#eab308"
              },
              {
                "min": 4,
                "max": 5,
                "color": "#22c55e"
              }
            ]
          }
        },
        {
          "id": "notes",
          "header": "Notes",
          "type": "textarea",
          "width": "250px"
        }
      ]
    },
    {
      "id": "compliance_tracker",
      "name": "Compliance Tracker",
      "type": "table",
      "columns": [
        {
          "id": "date_reported",
          "header": "Date Reported",
          "type": "date"
        },
        {
          "id": "violation",
          "header": "Violation",
