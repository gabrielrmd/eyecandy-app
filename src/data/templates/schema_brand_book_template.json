        {
          "id": "touchpoint",
          "header": "Touchpoint",
          "type": "text"
        },
        {
          "id": "category",
          "header": "Category",
          "type": "text",
          "editable": false
        },
        {
          "id": "severity",
          "header": "Severity",
          "type": "text"
        },
        {
          "id": "reporter",
          "header": "Reporter",
          "type": "text"
        },
        {
          "id": "status",
          "header": "Status",
          "type": "dropdown",
          "options": [
            "Not Started",
            "In Progress",
            "Done",
            "On Hold",
            "Cancelled"
          ]
        },
        {
          "id": "resolution",
          "header": "Resolution",
          "type": "text"
        },
        {
          "id": "resolved_date",
          "header": "Resolved Date",
          "type": "date"
        }
      ],
      "groupBy": "category"
    }
  ],
