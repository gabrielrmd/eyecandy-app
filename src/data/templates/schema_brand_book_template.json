        },
        {
          "id": "format",
          "header": "Format",
          "type": "text"
        },
        {
          "id": "version",
          "header": "Version",
          "type": "text"
        },
        {
          "id": "last_updated",
          "header": "Last Updated",
          "type": "date"
        },
        {
          "id": "status",
          "header": "Status",
          "type": "dropdown",
          "options": [
            "Not Started",
            "In Progress",
            "Done",
            "On Hold",
            "Cancelled"
