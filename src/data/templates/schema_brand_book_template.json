{
  "id": "brand_book_template",
  "name": "Brand Book Template",
  "category": "brand",
  "sheets": [
    {
      "id": "dashboard",
      "name": "Dashboard",
      "type": "summary"
    },
    {
      "id": "brand_foundation",
      "name": "Brand Foundation",
      "type": "form",
      "fields": [
        {
          "id": "why_does_your_brand_exist_beyond_making_",
          "label": "Why does your brand exist beyond making money? What change do you want to create in the world?",
          "type": "text"
        },
        {
          "id": "what_you_do_who_you_do_it_for_and_how_yo",
          "label": "What you do, who you do it for, and how you do it differently. Keep it under 25 words.",
          "type": "text"
        },
        {
          "id": "where_you_aspire_to_be_paint_a_picture_o",
          "label": "Where you aspire to be. Paint a picture of the future your brand is helping to create.",
          "type": "text"
        },
        {
          "id": "the_single_most_important_commitment_you",
          "label": "The single most important commitment you make to your customers.",
          "type": "text"
        },
        {
          "id": "list_3_5_core_values_that_guide_everythi",
          "label": "List 3-5 core values that guide everything your brand does. Be specific — not generic.",
          "type": "textarea"
        },
        {
          "id": "if_your_brand_were_a_person_how_would_yo",
          "label": "If your brand were a person, how would you describe them? List 5 personality traits.",
          "type": "textarea"
        },
        {
          "id": "which_archetype_best_represents_your_bra",
          "label": "Which archetype best represents your brand? (e.g., Hero, Explorer, Sage, Creator, Caregiver, Rebel)",
          "type": "text"
        },
        {
          "id": "who_is_your_primary_audience_describe_de",
          "label": "Who is your primary audience? Describe demographics, psychographics, and behaviors.",
          "type": "text"
        },
        {
          "id": "how_you_want_to_be_perceived_relative_to",
          "label": "How you want to be perceived relative to competitors. Complete: For [audience] who [need], [brand] is the [category] that [differentiator] because [reason to believe].",
          "type": "text"
        },
        {
          "id": "what_makes_you_fundamentally_different_f",
          "label": "What makes you fundamentally different from alternatives? List 3 key differentiators.",
          "type": "text"
        },
        {
          "id": "your_origin_story_why_you_started_what_d",
          "label": "Your origin story — why you started, what drives you, the problem you saw and set out to solve.",
          "type": "textarea"
        }
      ]
    },
    {
      "id": "visual_identity",
      "name": "Visual Identity",
      "type": "form",
      "fields": [
        {
          "id": "description",
          "label": "Description",
          "type": "textarea",
          "hint": "File Location",
          "placeholder": "File Location"
        },
        {
          "id": "main_logo_for_most_applications",
          "label": "Main logo for most applications",
          "type": "text"
        },
        {
          "id": "logo_with_tagline",
          "label": "Logo with tagline",
          "type": "text"
        },
        {
          "id": "simplified_mark_for_small_spaces",
          "label": "Simplified mark for small spaces",
          "type": "text"
        },
        {
          "id": "single_colour_version",
          "label": "Single-colour version",
          "type": "text"
        },
        {
          "id": "white_version_for_dark_backgrounds",
          "label": "White version for dark backgrounds",
          "type": "text"
        },
        {
          "id": "smallest_acceptable_reproduction",
          "label": "Smallest acceptable reproduction",
          "type": "text"
        },
        {
          "id": "minimum_space_around_logo",
          "label": "Minimum space around logo",
          "type": "text"
        },
        {
          "id": "what_not_to_do_with_the_logo",
          "label": "What NOT to do with the logo",
          "type": "text"
        },
        {
          "id": "role",
          "label": "Role",
          "type": "text",
          "hint": "RGB",
          "placeholder": "RGB"
        },
        {
          "id": "primary_brand_colour",
          "label": "Primary brand colour",
          "type": "text",
          "hint": "42, 185, 176",
          "placeholder": "42, 185, 176"
        },
        {
          "id": "secondary",
          "label": "Secondary",
          "type": "text",
          "hint": "0, 180, 216",
          "placeholder": "0, 180, 216"
        },
        {
          "id": "body_text",
          "label": "Body text",
          "type": "text",
          "hint": "51, 51, 51",
          "placeholder": "51, 51, 51"
        },
        {
          "id": "status_accent",
          "label": "Status/accent",
          "type": "text",
          "hint": "142, 209, 106",
          "placeholder": "142, 209, 106"
        },
        {
          "id": "status_accent",
          "label": "Status/accent",
          "type": "text",
          "hint": "242, 140, 40",
          "placeholder": "242, 140, 40"
        },
        {
          "id": "status_accent",
          "label": "Status/accent",
          "type": "text",
          "hint": "248, 206, 48",
          "placeholder": "248, 206, 48"
        },
        {
          "id": "role",
          "label": "Role",
          "type": "text",
          "hint": "Size",
          "placeholder": "Size"
        },
        {
          "id": "primary_heading",
          "label": "Primary Heading",
          "type": "text",
          "hint": "20-32pt",
          "placeholder": "20-32pt"
        },
        {
          "id": "secondary_heading",
          "label": "Secondary Heading",
          "type": "text",
          "hint": "16-20pt",
          "placeholder": "16-20pt"
        },
        {
          "id": "body_text",
          "label": "Body Text",
          "type": "text",
          "hint": "11-14pt",
          "placeholder": "11-14pt"
        },
        {
          "id": "caption",
          "label": "Caption",
          "type": "text",
          "hint": "9-10pt",
          "placeholder": "9-10pt"
        },
        {
          "id": "cta_button",
          "label": "CTA / Button",
          "type": "text",
          "hint": "12-14pt",
          "placeholder": "12-14pt"
        }
      ]
    },
    {
      "id": "tone_of_voice",
      "name": "Tone of Voice",
      "type": "table",
      "columns": [
        {
          "id": "characteristic",
          "header": "Characteristic",
          "type": "text"
        },
        {
          "id": "we_are",
          "header": "We Are",
          "type": "text"
        },
        {
          "id": "we_are_not",
          "header": "We Are Not",
          "type": "text"
        },
        {
          "id": "example_do",
          "header": "Example (Do)",
          "type": "text"
        },
        {
          "id": "example_don_t",
          "header": "Example (Don't)",
          "type": "text"
        }
      ]
    },
    {
      "id": "messaging_architecture",
      "name": "Messaging Architecture",
      "type": "form",
      "fields": [
        {
          "id": "a_memorable_phrase_that_captures_your_br",
          "label": "A memorable phrase that captures your brand essence (under 8 words)",
          "type": "text"
        },
        {
          "id": "30_second_description_of_who_you_are_wha",
          "label": "30-second description of who you are, what you do, and why it matters",
          "type": "textarea"
        },
        {
          "id": "2_3_sentence_brand_positioning_statement",
          "label": "2-3 sentence brand positioning statement for internal alignment",
          "type": "text"
        },
        {
          "id": "standard_company_description_for_press_r",
          "label": "Standard company description for press releases and official documents",
          "type": "textarea"
        },
        {
          "id": "key_message",
          "label": "Key Message",
          "type": "text",
          "hint": "Proof Points",
          "placeholder": "Proof Points"
        },
        {
          "id": "pain_point",
          "label": "Pain Point",
          "type": "text",
          "hint": "Value Proposition",
          "placeholder": "Value Proposition"
        }
      ]
    },
    {
      "id": "application_guidelines",
      "name": "Application Guidelines",
      "type": "table",
      "columns": [
        {
          "id": "touchpoint",
          "header": "Touchpoint",
          "type": "text"
        },
        {
          "id": "category",
          "header": "Category",
          "type": "text",
          "editable": false
        },
        {
          "id": "brand_elements",
          "header": "Brand Elements",
          "type": "text"
        },
        {
          "id": "specifications",
          "header": "Specifications",
          "type": "text"
        },
        {
          "id": "do",
          "header": "Do",
          "type": "text"
        },
        {
          "id": "don_t",
          "header": "Don't",
          "type": "text"
        },
        {
          "id": "template_available",
          "header": "Template Available",
          "type": "text"
        },
        {
          "id": "status",
          "header": "Status",
          "type": "dropdown",
          "options": [
            "Not Started",
            "In Progress",
            "Done",
            "On Hold",
            "Cancelled"
          ]
        }
      ],
      "groupBy": "category"
    },
    {
      "id": "asset_library",
