          "min": 1,
          "max": 5,
          "colorScale": {
            "ranges": [
              {
                "min": 1,
                "max": 2,
                "color": "#ef4444"
              },
              {
                "min": 3,
                "max": 3,
                "color": "#eab308"
              },
              {
                "min": 4,
                "max": 5,
                "color": "#22c55e"
              }
            ]
          }
        },
        {
          "id": "spend",
          "header": "Spend",
          "type": "date"
        },
        {
          "id": "roas",
          "header": "ROAS",
          "type": "percentage"
