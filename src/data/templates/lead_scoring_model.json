{
  "id": "lead_scoring_model",
  "name": "Lead Scoring Model",
  "number": 10,
  "category": "growth",
  "description": "Lead Scoring Model - Marketing template for growth professionals",
  "instructions": "How to Use This Template Step 1: Define Scoring Criteria Go to the Scoring Criteria tab. Review and customize the FIT criteria (demographics, firmographics) and ENGAGEMENT criteria (behavioral signals). Adjust point values to match your business. Step 2: Set Thresholds In the Scoring Criteria tab, define your threshold ranges: what total score makes a lead Cold, Warm, Marketing Qualified (MQL), or Sales Qualified (SQL). Step 3: Score Your Leads Go to the Lead Scorer tab. Enter each lead and check which criteria they meet. The template auto-calculates their FIT score, ENGAGEMENT score, and Tota",
  "icon": "trending-up",
  "tags": [
    "growth"
  ],
  "estimatedTime": "65 min",
  "dashboard": {
    "metrics": [
      {
        "label": "Auto-calculated from your Lead Scorer data",
        "calculation": "Count of records",
        "format": "number"
      },
      {
        "label": "Total Leads",
        "calculation": "3",
        "format": "number"
      },
      {
        "label": "PIPELINE BY STAGE",
        "calculation": "Count of records",
        "format": "number"
      },
      {
        "label": "Stage",
        "calculation": "Count",
        "format": "number"
      },
      {
        "label": "Cold",
        "calculation": "Count of records",
        "format": "number"
      }
    ]
  },
