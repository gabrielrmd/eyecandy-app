{
  "id": "nps_template",
  "name": "NPS Template",
  "category": "research",
  "sheets": [
    {
      "id": "dashboard",
      "name": "Dashboard",
      "type": "summary"
    },
    {
      "id": "response_log",
      "name": "Response Log",
      "type": "table",
      "columns": [
        {
          "id": "response_id",
          "header": "Response ID",
          "type": "text"
        },
        {
          "id": "date",
          "header": "Date",
          "type": "date"
        },
        {
          "id": "customer_name",
          "header": "Customer Name",
          "type": "text"
        },
        {
          "id": "email",
          "header": "Email",
          "type": "text"
        },
        {
          "id": "segment",
          "header": "Segment",
          "type": "text"
        },
        {
          "id": "product_service",
          "header": "Product/Service",
          "type": "text"
        },
        {
          "id": "nps_score",
          "header": "NPS Score",
          "type": "score",
          "min": 1,
          "max": 5,
          "colorScale": {
            "ranges": [
              {
                "min": 1,
                "max": 2,
                "color": "#ef4444"
              },
              {
                "min": 3,
                "max": 3,
                "color": "#eab308"
              },
              {
                "min": 4,
                "max": 5,
                "color": "#22c55e"
              }
            ]
          }
        },
        {
          "id": "category",
          "header": "Category",
          "type": "text",
          "editable": false
        },
        {
          "id": "verbatim_feedback",
          "header": "Verbatim Feedback",
          "type": "currency"
        },
        {
          "id": "follow_up_status",
          "header": "Follow-up Status",
          "type": "dropdown",
          "options": [
            "Not Started",
            "In Progress",
            "Done",
            "On Hold",
            "Cancelled"
          ]
        },
        {
          "id": "follow_up_owner",
          "header": "Follow-up Owner",
          "type": "text"
        },
        {
          "id": "follow_up_date",
          "header": "Follow-up Date",
          "type": "date"
        }
      ],
      "groupBy": "category"
    },
    {
      "id": "trend_analysis",
      "name": "Trend Analysis",
      "type": "table",
      "columns": [
        {
          "id": "month",
          "header": "Month",
          "type": "text"
        },
        {
          "id": "total_responses",
          "header": "Total Responses",
          "type": "number"
        },
        {
          "id": "promoters_count",
          "header": "Promoters Count",
          "type": "number"
        },
        {
          "id": "passives_count",
          "header": "Passives Count",
          "type": "number"
        },
        {
          "id": "detractors_count",
          "header": "Detractors Count",
          "type": "number"
        },
        {
          "id": "promoters",
          "header": "% Promoters",
          "type": "percentage"
        },
        {
          "id": "passives",
          "header": "% Passives",
          "type": "percentage"
        },
        {
          "id": "detractors",
          "header": "% Detractors",
          "type": "percentage"
        },
        {
          "id": "nps_score",
          "header": "NPS Score",
          "type": "score",
          "min": 1,
          "max": 5,
          "colorScale": {
            "ranges": [
              {
                "min": 1,
                "max": 2,
                "color": "#ef4444"
              },
              {
                "min": 3,
                "max": 3,
