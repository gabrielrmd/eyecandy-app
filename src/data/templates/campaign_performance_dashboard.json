{
  "id": "campaign_performance_dashboard",
  "name": "Campaign Performance Dashboard",
  "number": 11,
  "category": "analytics",
  "description": "Campaign Performance Dashboard - Marketing template for analytics professionals",
  "instructions": "How to Use This Template Step 1: Log Your Campaigns Go to the Campaign Log tab. Enter every campaign — name, channel, type, dates, budget, and target audience. One row per campaign. Step 2: Track Results As campaigns run, update the results columns: Impressions, Clicks, Leads, Conversions, Revenue, and Actual Spend. The template auto-calculates CTR, CPC, CPL, CPA, and ROI. Step 3: Score Each Campaign Use the Status dropdown to mark campaigns as Planning, Active, Paused, Completed, or Cancelled. Add a performance rating (1-5) when done. Step 4: Analyze by Channel The Channel Analysis tab auto-a",
  "icon": "bar-chart",
  "tags": [
    "analytics"
  ],
  "estimatedTime": "55 min",
  "dashboard": {
    "metrics": [
      {
        "label": "Auto-calculated from Campaign Log",
        "calculation": "Count of records",
        "format": "number"
      },
      {
        "label": "Total Campaigns",
        "calculation": "Active",
        "format": "number"
      },
      {
        "label": "Total Impressions",
        "calculation": "Total Clicks",
        "format": "number"
      },
      {
        "label": "EFFICIENCY METRICS",
        "calculation": "Count of records",
        "format": "number"
      },
      {
        "label": "Avg CTR",
        "calculation": "Avg CPC",
        "format": "number"
      }
    ]
  },
